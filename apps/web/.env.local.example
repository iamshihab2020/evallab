# EvalLab frontend env. Copy to .env.local and fill in values.
#
# NEXT_PUBLIC_API_BASE_URL: where the FastAPI backend lives.
#   Local dev: http://localhost:8000
#   Production (Phase 6): your Render service URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# NEXT_PUBLIC_API_KEY: must match EVALLAB_API_KEY on the backend.
#   Leave empty in local dev. Set in production (Phase 6).
NEXT_PUBLIC_API_KEY=

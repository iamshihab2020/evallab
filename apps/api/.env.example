# EvalLab backend env. Copy to .env and fill in values.
#
# DATABASE_URL: Postgres connection string for your Neon dev branch.
#   Get it from https://console.neon.tech (Connection Details → connection string).
#   IMPORTANT: rewrite the scheme from `postgresql://` to `postgresql+asyncpg://`
#   so SQLAlchemy uses the async driver. Example:
#     postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/evallab?ssl=require
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/DB

# GROQ_API_KEY: get one (free, no card) at https://console.groq.com.
#   Not required until Phase 3 (LLM client). Leave blank for Phase 1-2 work.
GROQ_API_KEY=

# EVALLAB_API_KEY: optional. If set, every request must send `X-API-Key: <value>`.
#   Leave empty in local dev. Set in production (Phase 6).
EVALLAB_API_KEY=

# CORS_ORIGINS: comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000
